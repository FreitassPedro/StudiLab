generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Subject {
  id         String   @id @default(uuid())
  name       String
  color      String
  icon String?
  created_at DateTime @default(now()) @db.Timestamptz(3)
  userId     String
  isArchived Boolean
  isOpen     Boolean
  user       User     @relation(fields: [userId], references: [id])
  topics     Topic[]
}

model Topic {
  id        String                @id @default(uuid())
  name      String
  subjectId String
  parentId  String?
  path      Unsupported("ltree")?
  studyLogs StudyLogs[]
  parent    Topic?                @relation("TopicChildren", fields: [parentId], references: [id])
  children  Topic[]               @relation("TopicChildren")
  subject   Subject               @relation(fields: [subjectId], references: [id])

  @@unique([parentId, name])
  @@index([path], type: Gist)
}

model StudyLogs {
  id               String   @id @default(uuid())
  study_date       DateTime @db.Date
  topicId          String
  start_time       DateTime @db.Timestamptz(3)
  end_time         DateTime @db.Timestamptz(3)
  duration_minutes Int
  notes            String?
  created_at       DateTime @default(now()) @db.Timestamptz(3)
  updated_at       DateTime @updatedAt @db.Timestamptz(3)
  material_type    String?
  topic            Topic    @relation(fields: [topicId], references: [id])
}

model User {
  id            String     @id
  name          String
  email         String     @unique
  emailVerified Boolean    @default(false)
  image         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  subjects      Subject[]
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  stats         UserStats?
  followers     Follows[]  @relation("Following")
  following     Follows[]  @relation("Follower")
  badges        UserBadge[]
  dailyStats    UserDailyStats[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  username    String   @unique
  bio         String?  
  isPublic    Boolean  @default(false)
  
  coverImage  String?
  
  webSite   String?
  theme     String   @default("midnight")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Follows {
  followerId  String
  followingId String
  
  follower    User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Badge {
  id          String      @id @default(uuid())
  name        String      @unique
  description String
  emoji       String
  rarity      String      
  users       UserBadge[]
}

model UserBadge {
  userId    String
  badgeId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  unlockedAt DateTime @default(now())

  @@id([userId, badgeId])
}

/// Tabela desnormalizada com métricas pré-calculadas por usuário.
/// Atualizada incrementalmente em cada mutação de StudyLog — nunca calculada em tempo de request.
model UserStats {
  userId        String    @id
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Dias consecutivos de estudo até hoje (ou ontem se ainda não estudou hoje)
  currentStreak Int       @default(0)
  /// Maior ofensiva já registrada
  longestStreak Int       @default(0)
  /// Data da última sessão de estudo (UTC Date)
  lastStudyDate DateTime? @db.Date

  /// Total de minutos estudados (histórico completo)
  totalMinutes  Int       @default(0)
  /// Total de sessões criadas (histórico completo)
  totalSessions Int       @default(0)
  /// Minutos estudados na semana corrente (seg–dom)
  weeklyMinutes Int       @default(0)
  /// Número de dias únicos com pelo menos uma sessão
  studyDays     Int       @default(0)

  updatedAt     DateTime  @updatedAt
}

model UserDailyStats {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime @db.Date  // O dia exato (sem horas)
  totalMinutes Int      @default(0)
  sessions     Int      @default(0)

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Garante que só existe 1 linha por dia para cada usuário
  @@unique([userId, date])
  @@index([userId, date(sort: Desc)])
}
